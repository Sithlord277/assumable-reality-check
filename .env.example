# Copy this file to .env.local and fill in the values. .env.local is gitignored.
# All keys are NEXT_PUBLIC_ because this is a no-backend app; these run in the browser.

# --- EmailJS: powers "email me my results" (https://www.emailjs.com) ---
# These are PUBLIC keys and are safe to expose in client-side code.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NEXT_PUBLIC_EMAILJS_TEMPLATE_USER=
NEXT_PUBLIC_EMAILJS_TEMPLATE_MARTIN=

# --- Calendly: the "book a call" step ---
# Option A: set one general link and leave the per-result links blank.
# Option B: set a different link per result type. Blank per-result links fall back
# to the general link automatically.
NEXT_PUBLIC_CALENDLY_GENERAL=
NEXT_PUBLIC_CALENDLY_PORTAL_WALKTHROUGH=
NEXT_PUBLIC_CALENDLY_NUMBERS_REVIEW=
NEXT_PUBLIC_CALENDLY_STRATEGY_CALL=
